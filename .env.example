# SELLM 环境变量示例 —— 复制为 .env 并填入真实值后使用(.env 已被 .gitignore 忽略,勿提交真实密钥)
# 后端通过 ${ENV:default} 注入;未设置时使用各自默认值(见 application.yml)

# ── 数据库(生产 application.yml 用 MySQL;dev profile 用 H2 文件库,无需配)──
DB_USER=root
DB_PASSWORD=

# ── 安全密钥(生产必配;dev profile 内置开发用默认值)──
# AES 字段加密密钥:必须恰好 32 字节(AES-256),用于儿童/家长姓名等 PII 落库加密
SELLM_AES_KEY=
# JWT 签名密钥:至少 32 字节
# P1:API 网关用同一密钥验签;白名单(/api/auth/、/actuator/health)免鉴权;
#     验签通过后网关注入 X-User-Id/X-User-Name/X-User-Role/X-Org-Id 到下游
SELLM_JWT_SECRET=

# ── 微信小程序登录(家长端 code2session;未配则 /api/auth/wechat-login 返回明确错误)──
# AppID/AppSecret 取自微信公众平台;DEFAULT_ORG_ID 为新建微信家长默认机构(可空,待管理端分配)
SELLM_WECHAT_APP_ID=
SELLM_WECHAT_APP_SECRET=
SELLM_WECHAT_DEFAULT_ORG_ID=

# ── 大模型(默认 mock,不外联;配置后切真实模型)──
# provider: mock(默认,不调用外部) | openai(OpenAI 兼容接口)
SELLM_AI_PROVIDER=mock
# OpenAI 兼容服务地址(适配器会自动拼 /v1/chat/completions)
#   通义千问: https://dashscope.aliyuncs.com/compatible-mode
#   DeepSeek:  https://api.deepseek.com
#   Moonshot:  https://api.moonshot.cn
SELLM_AI_BASE_URL=
# API Key(切勿提交;泄露后到对应控制台轮换)
SELLM_AI_API_KEY=
# 模型名:通义 qwen-plus / DeepSeek deepseek-chat / OpenAI gpt-4o-mini 等
SELLM_AI_MODEL=gpt-4o-mini
# 请求超时秒数:大模型生成长报告/IEP 常需 20-45s,默认 60
SELLM_AI_TIMEOUT=60

# ── PDF 导出 ──
# CJK 字体文件路径(导出中文 PDF 必需);缺失时英文正常、中文缺字形
#   Windows 示例: C:/Windows/Fonts/simhei.ttf
#   Linux 示例:   /usr/share/fonts/truetype/...（思源黑体等）
SELLM_PDF_FONT_PATH=

# ── 对象存储(评估媒体;默认 noop 本地落盘,不外联)──
# provider: noop(默认,本地目录) | minio
SELLM_MINIO_PROVIDER=noop
SELLM_MINIO_ENDPOINT=
SELLM_MINIO_ACCESS_KEY=
SELLM_MINIO_SECRET_KEY=
SELLM_MINIO_BUCKET=sellm-media
SELLM_MINIO_LOCAL_DIR=data/media

# ── 多模态评估模型(默认 mock,不外联)──
# ⚠️ 重要:openai 会把含儿童面部的图片发往第三方,无法像文本那样脱敏。
#    启用即代表已获监护人知情同意并自担合规风险。
# provider: mock(默认) | openai(OpenAI 兼容 vision,如通义 qwen-vl-plus)
SELLM_MULTIMODAL_PROVIDER=mock
SELLM_MULTIMODAL_BASE_URL=
SELLM_MULTIMODAL_API_KEY=
SELLM_MULTIMODAL_MODEL=qwen-vl-plus
SELLM_MULTIMODAL_TIMEOUT=90

# ── 语音识别 ASR(多模态诊断;默认 mock 不外联)──
# ⚠️ openai 会把含儿童语音的音频发往第三方,无法脱敏;启用即代表已获监护人知情同意并自担合规风险。
# provider: mock(默认) | openai(OpenAI 兼容 ASR,如 whisper-1)
SELLM_SPEECH_PROVIDER=mock
SELLM_SPEECH_BASE_URL=
SELLM_SPEECH_API_KEY=
SELLM_SPEECH_MODEL=whisper-1
SELLM_SPEECH_TIMEOUT=90

# ── 图像脱敏(vision 出网前;默认 noop 不改图)──
# provider: noop(默认) | http(POST 图片到外部 CV 打码服务,返回打码后图片)
# 真实 vision 启用时,图像出网前必经此层;http 失败会硬阻断(绝不让原图出网)
SELLM_IMAGE_ANON_PROVIDER=noop
SELLM_IMAGE_ANON_ENDPOINT=
SELLM_IMAGE_ANON_API_KEY=
SELLM_IMAGE_ANON_TIMEOUT=30

# ══════════════════════════════════════════════════
# P0 平台基础设施(docker-compose 外部依赖连接)
# ══════════════════════════════════════════════════

# ── Nacos 注册发现/配置中心 ──
SELLM_NACOS_ADDR=127.0.0.1:8848

# ── RabbitMQ 事件总线 ──
SELLM_RABBITMQ_HOST=127.0.0.1
SELLM_RABBITMQ_PORT=5672
SELLM_RABBITMQ_USER=sellm
SELLM_RABBITMQ_PASS=sellm_dev

# ── Redis(网关限流/缓存/幂等去重)──
SELLM_REDIS_HOST=127.0.0.1
SELLM_REDIS_PORT=6379

# ── API 网关限流(P3,固定窗口,按用户(X-User-Id)/IP;Redis 不可用时 fail-open 放行)──
SELLM_RATELIMIT_ENABLED=true
SELLM_RATELIMIT_LIMIT=100
SELLM_RATELIMIT_WINDOW=60

# ── Milvus 向量库 ──
SELLM_MILVUS_HOST=127.0.0.1
SELLM_MILVUS_PORT=19530

# ── Python 智能层(所有 agent 共用,sellm-agent-common 提供 sellm.smart-layer.*)──
SELLM_SMARTLAYER_URL=http://localhost:8090
SELLM_SMARTLAYER_TIMEOUT=30
# 注:SELLM_SMARTLAYER_TOPK 已废弃(qa 改用本地常量 DEFAULT_TOP_K)

# ── agent-teaching 课件产物存储(P5,默认 Noop 本地落盘)──
SELLM_STORAGE_LOCAL_DIR=data/media

# ── 文生媒体适配器(agent-aids 文生素材,Python 智能层,默认 mock 不外联)──
# provider=openai 且配 API_KEY 时启用真实图像生成;否则 Mock 产占位二进制(1x1 PNG/静音 WAV)
# ⚠️ 真实生成会把(已脱敏的)prompt 发往第三方,合规风险由配置方承担
SELLM_MEDIA_PROVIDER=mock
SELLM_MEDIA_BASE_URL=
SELLM_MEDIA_API_KEY=
SELLM_MEDIA_MODEL=dall-e-3
SELLM_MEDIA_TIMEOUT=120

# ── 文生视频适配器(agent-aids VIDEO 素材,Python 智能层,默认 mock 不外联)──
# provider=openai 且配 API_KEY 时启用真实视频生成(异步:提交→轮询→下载);否则 Mock 产占位 mp4
# ⚠️ 真实生成会把(已脱敏的)prompt 发往第三方,合规风险由配置方承担
SELLM_VIDEO_PROVIDER=mock
SELLM_VIDEO_BASE_URL=
SELLM_VIDEO_API_KEY=
SELLM_VIDEO_MODEL=sora-1
SELLM_VIDEO_TIMEOUT=300
SELLM_VIDEO_POLL_INTERVAL=5
SELLM_VIDEO_MAX_POLLS=60

# ── 安全加固后新增(2026-06)──
# 网关/各服务 JWT 密钥须 ≥32 字节,缺失则启动失败(fail-fast,防认证绕过)
# dev 联调起网关用 -Dspring-boot.run.profiles=dev 提供开发默认密钥
# dev 单进程联调默认关 Nacos 注册;验网关路由时设 true
SELLM_NACOS_ENABLED=false
# 各 Agent 独立 MySQL 生产库(dev 用 application-dev.yml 的 H2,无需配)
SELLM_QA_DB_URL=
SELLM_QA_DB_USER=root
SELLM_QA_DB_PASSWORD=
SELLM_RESEARCH_DB_URL=
SELLM_RESEARCH_DB_USER=root
SELLM_RESEARCH_DB_PASSWORD=
SELLM_TEACHING_DB_URL=
SELLM_TEACHING_DB_USER=root
SELLM_TEACHING_DB_PASSWORD=
SELLM_AIDS_DB_URL=
SELLM_AIDS_DB_USER=root
SELLM_AIDS_DB_PASSWORD=
# 文生图尺寸(万相用 * 分隔,如 1024*1024);wanx provider 时 base-url=https://dashscope.aliyuncs.com
SELLM_MEDIA_SIZE=1024*1024
