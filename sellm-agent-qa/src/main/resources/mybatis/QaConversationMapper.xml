<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sellm.qa.QaConversationMapper">
    <resultMap id="convMap" type="map">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="title" property="title"/>
    </resultMap>
    <insert id="insert" parameterType="map" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO qa_conversation (user_id, title) VALUES (#{userId}, #{title})
    </insert>
    <select id="findById" parameterType="long" resultMap="convMap">
        SELECT id, user_id, title FROM qa_conversation WHERE id = #{id} AND deleted = 0
    </select>
    <select id="findByUserId" parameterType="long" resultMap="convMap">
        SELECT id, user_id, title FROM qa_conversation WHERE user_id = #{userId} AND deleted = 0 ORDER BY id DESC
    </select>
</mapper>
