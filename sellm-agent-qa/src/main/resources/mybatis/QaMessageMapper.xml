<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sellm.qa.QaMessageMapper">
    <resultMap id="msgMap" type="map">
        <id column="id" property="id"/>
        <result column="conversation_id" property="conversationId"/>
        <result column="role" property="role"/>
        <result column="content" property="content"/>
        <result column="route_to" property="routeTo"/>
        <result column="sources" property="sources"/>
    </resultMap>
    <insert id="insert" parameterType="map" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO qa_message (conversation_id, role, content, route_to, sources)
        VALUES (#{conversationId}, #{role}, #{content}, #{routeTo}, #{sources})
    </insert>
    <select id="findByConversationId" parameterType="long" resultMap="msgMap">
        SELECT id, conversation_id, role, content, route_to, sources
        FROM qa_message WHERE conversation_id = #{conversationId} AND deleted = 0 ORDER BY id ASC
    </select>
</mapper>
